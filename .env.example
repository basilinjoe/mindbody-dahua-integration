# MindBody API
MINDBODY_API_KEY=your_api_key_here
MINDBODY_SITE_ID=-99
MINDBODY_USERNAME=staff_username
MINDBODY_PASSWORD=staff_password
MINDBODY_WEBHOOK_SIGNATURE_KEY=

# Dahua — Option A: Single default device
DAHUA_DEFAULT_HOST=192.168.1.100
DAHUA_DEFAULT_PORT=80
DAHUA_DEFAULT_USERNAME=admin
DAHUA_DEFAULT_PASSWORD=device_password
DAHUA_DEFAULT_DOOR_IDS=0

# Dahua — Option B: Multiple devices (JSON array, takes priority over Option A)
# Each object: name, host, port (default 80), username (default "admin"), password, door_ids (default "0")
# DAHUA_DEVICES=[{"name":"Main Entrance","host":"192.168.1.100","password":"pass1","door_ids":"0"},{"name":"Back Gate","host":"192.168.1.101","password":"pass2","door_ids":"0,1"},{"name":"Side Door","host":"192.168.1.102","password":"pass3"}]
DAHUA_DEVICES=

# Application
DATABASE_URL=sqlite:///./data/sync.db
SYNC_INTERVAL_MINUTES=30
DEVICE_HEALTH_INTERVAL_MINUTES=5
LOG_LEVEL=INFO
PHOTO_MAX_SIZE_KB=190

# Admin UI
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
SECRET_KEY=change-this-to-a-long-random-string
SESSION_EXPIRE_HOURS=8
