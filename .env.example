# PostgreSQL
POSTGRES_PASSWORD=changeme

# Admin UI
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
SECRET_KEY=change-this-to-a-random-secret-key

# MindBody
# The worker auto-creates the Prefect block 'production' from these on startup.
# If omitted, create the block manually via the Prefect UI (localhost:4200 → Blocks).
MINDBODY_API_KEY=your-api-key
MINDBODY_SITE_ID=-99
MINDBODY_USERNAME=your-username
MINDBODY_PASSWORD=your-password
MINDBODY_WEBHOOK_SIGNATURE_KEY=your-webhook-signature-key

# Prefect
PREFECT_API_URL=http://prefect-server:4200/api

# Prefect Variables (optional — override defaults set in the Prefect UI)
SYNC_INTERVAL_MINUTES=30
HEALTH_INTERVAL_MINUTES=5
