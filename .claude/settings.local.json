{
  "permissions": {
    "allow": [
      "Bash(printf:*)",
      "WebFetch(domain:files.dahua.support)",
      "WebFetch(domain:github.com)",
      "Bash(python -m py_compile:*)",
      "Bash(uv pip install:*)",
      "Bash(git init:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(ls c:/Projects/mind-body-dahua/*.env)",
      "mcp__plugin_serena_serena__read_file",
      "mcp__plugin_serena_serena__list_dir",
      "mcp__plugin_serena_serena__activate_project",
      "mcp__plugin_serena_serena__search_for_pattern",
      "WebSearch",
      "WebFetch(domain:docs.prefect.io)",
      "WebFetch(domain:reference.prefect.io)",
      "Bash(python -m pytest tests/unit/app/test_main.py -q --tb=long)",
      "Bash(python -m pytest tests/unit/app/ tests/unit/api/ -q --tb=short)",
      "Bash(python -m pytest tests/ -q --tb=short)",
      "Bash(docker compose:*)",
      "Bash(python -m pytest tests/ -v --tb=short)",
      "Bash(python -m pytest tests/unit/admin/ tests/unit/sync/test_integration_plan_group.py -q)",
      "mcp__plugin_playwright_playwright__browser_navigate",
      "Bash(curl -s http://localhost:54370)",
      "Bash(python -m pytest tests/unit/admin/test_dashboard_stats.py -v)",
      "Bash(python -m pytest --co -q tests/unit/admin/test_dashboard_stats.py)",
      "Bash(pytest tests/unit/admin/test_dashboard_stats.py -v)",
      "Bash(python -m pytest tests/unit/admin/test_device_user_count.py -v)",
      "Bash(pytest -q)",
      "Bash(python -m pytest tests/unit/admin/ -v)",
      "Bash(.venv/Scripts/pytest --cov=app --cov-report=term-missing --cov-fail-under=85)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python c:/projects/mindbody-dahua-integration/.claude/hooks/ruff_check.py"
          },
          {
            "type": "agent",
            "prompt": "A file was just modified. Review ONLY that file for code quality, reuse, and efficiency. Simplify and refine it for clarity, consistency, and maintainability while preserving all functionality. Do not change behaviour — only improve structure and readability. The modified file path is in: $ARGUMENTS",
            "statusMessage": "Simplifying code..."
          }
        ]
      }
    ]
  }
}
