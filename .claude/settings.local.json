{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python c:/Projects/mind-body-dahua/.claude/hooks/ruff_check.py"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(printf:*)",
      "WebFetch(domain:files.dahua.support)",
      "WebFetch(domain:github.com)",
      "Bash(python -m py_compile:*)",
      "Bash(uv pip install:*)",
      "Bash(git init:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(ls c:/Projects/mind-body-dahua/*.env)",
      "mcp__plugin_serena_serena__read_file",
      "mcp__plugin_serena_serena__list_dir",
      "mcp__plugin_serena_serena__activate_project",
      "mcp__plugin_serena_serena__search_for_pattern",
      "WebSearch",
      "WebFetch(domain:docs.prefect.io)",
      "WebFetch(domain:reference.prefect.io)",
      "Bash(python -m pytest tests/unit/app/test_main.py -q --tb=long)",
      "Bash(python -m pytest tests/unit/app/ tests/unit/api/ -q --tb=short)",
      "Bash(python -m pytest tests/ -q --tb=short)",
      "Bash(docker compose:*)",
      "Bash(python -m pytest tests/ -v --tb=short)",
      "Bash(python -m pytest tests/unit/admin/ tests/unit/sync/test_integration_plan_group.py -q)"
    ]
  }
}
